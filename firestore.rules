rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id.size() > 0 && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ENTITY VALIDATION HELPERS

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt', 'provider'])
          && data.keys().size() >= 3
          && data.uid is string
          && data.uid == request.auth.uid
          && data.createdAt is int
          && data.provider is string
          && data.provider.size() <= 32;
    }

    function isValidBook(data) {
      return data.keys().hasAll(['id', 'ownerUid', 'title', 'content'])
          && data.keys().size() >= 4
          && data.id is string
          && data.id.size() <= 64
          && data.ownerUid is string
          && data.ownerUid == request.auth.uid
          && data.title is string
          && data.title.size() <= 200
          && data.content is string
          && data.content.size() <= 2000000; // max size check to avoid excessive writes
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'ownerUid', 'timestamp', 'wordCount', 'durationSeconds'])
          && data.keys().size() >= 5
          && data.id is string
          && data.id.size() <= 64
          && data.ownerUid is string
          && data.ownerUid == request.auth.uid
          && data.timestamp is int
          && data.wordCount is int
          && data.durationSeconds is int;
    }

    function isValidDNA(data) {
      return data.keys().hasAll(['ownerUid', 'updatedAt'])
          && data.keys().size() >= 2
          && data.ownerUid is string
          && data.ownerUid == request.auth.uid
          && data.updatedAt is int;
    }

    // MATCH BLOCKS

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    match /library/{bookId} {
      allow get: if isSignedIn() && isValidId(bookId) && resource.data.ownerUid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(bookId) && isValidBook(request.resource.data);
      allow update: if isSignedIn() && isValidId(bookId) && resource.data.ownerUid == request.auth.uid && isValidBook(request.resource.data);
      allow delete: if isSignedIn() && isValidId(bookId) && resource.data.ownerUid == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow get: if isSignedIn() && isValidId(sessionId) && resource.data.ownerUid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(sessionId) && isValidSession(request.resource.data);
      allow update: if isSignedIn() && isValidId(sessionId) && resource.data.ownerUid == request.auth.uid && isValidSession(request.resource.data);
      allow delete: if isSignedIn() && isValidId(sessionId) && resource.data.ownerUid == request.auth.uid;
    }

    match /dna/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidDNA(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidDNA(request.resource.data);
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
